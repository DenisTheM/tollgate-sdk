{
  "name": "@tollgate/sdk",
  "version": "0.1.1",
  "description": "One-line API monetization with x402. Accept crypto payments with a single function call.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tollgate": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@x402/core": "^2.7.0",
    "@x402/evm": "^2.7.0"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "@x402/express": "^2.7.0",
    "@x402/mcp": "^2.7.0",
    "@x402/next": "^2.7.0",
    "express": ">=4.0.0",
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "@x402/express": {
      "optional": true
    },
    "@x402/next": {
      "optional": true
    },
    "@x402/mcp": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@x402/express": "^2.7.0",
    "@x402/mcp": "^2.7.0",
    "@x402/next": "^2.7.0",
    "express": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "api",
    "monetization",
    "x402",
    "crypto",
    "payments",
    "usdc",
    "base",
    "middleware",
    "express",
    "nextjs",
    "mcp"
  ]
}
